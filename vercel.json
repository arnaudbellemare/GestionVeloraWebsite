{
  "redirects": [
    {
      "source": "/faq",
      "destination": "/#faq",
      "permanent": true
    },
    {
      "source": "/en/faq",
      "destination": "/en/#faq",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "gestionvelora.com"
        }
      ],
      "destination": "https://www.gestionvelora.com/:path*",
      "permanent": true
    },
    {
      "source": "/en/en/:path*",
      "destination": "/en/:path*",
      "permanent": true
    },
    {
      "source": "/blog/",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/en/blog/",
      "destination": "/en/blog",
      "permanent": true
    }
  ],
  "rewrites": [
